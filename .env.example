# Required API keys. Leave blank in the example file.
OPENAI_API_KEY=
GEMINI_API_KEY=

# FLUX is supported through either name. Keep both blank in the template.
FLUX_API_KEY=
BFL_API_KEY=

# Seedance / Volcengine / Ark aliases.
SEEDANCE_API_KEY=
ARK_API_KEY=
BYTEPLUS_API_KEY=
VOLCENGINE_API_KEY=

# TTS.
ELEVENLABS_API_KEY=

# Optional base URLs.
OPENAI_BASE_URL=
GEMINI_BASE_URL=
BFL_BASE_URL=
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com
ELEVENLABS_BASE_URL=

# Optional provider-specific runtime settings.
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=
FLUX_ENDPOINT_ID=
SEEDANCE_ENDPOINT_ID=
VOLCENGINE_LAS_API_KEY=
LAS_API_KEY=
