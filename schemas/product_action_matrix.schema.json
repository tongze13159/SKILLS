{
  "$defs": {
    "ModelInfo": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelInfo",
      "type": "object"
    },
    "ProductAction": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "pattern": "^act_\\d{3}(?:_fallback)?$",
          "title": "Action Id",
          "type": "string"
        },
        "action_name": {
          "title": "Action Name",
          "type": "string"
        },
        "difficulty": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Difficulty",
          "type": "string"
        },
        "video_generation_risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Video Generation Risk",
          "type": "string"
        },
        "visual_clarity": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Visual Clarity",
          "type": "string"
        },
        "suitable_shot_functions": {
          "items": {
            "type": "string"
          },
          "title": "Suitable Shot Functions",
          "type": "array"
        },
        "required_props": {
          "items": {
            "type": "string"
          },
          "title": "Required Props",
          "type": "array"
        },
        "best_camera": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Best Camera",
          "type": "object"
        },
        "start_state": {
          "title": "Start State",
          "type": "string"
        },
        "main_motion": {
          "title": "Main Motion",
          "type": "string"
        },
        "end_state": {
          "title": "End State",
          "type": "string"
        },
        "avoid": {
          "items": {
            "type": "string"
          },
          "title": "Avoid",
          "type": "array"
        },
        "fallback_action_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fallback Action Id"
        }
      },
      "required": [
        "action_id",
        "action_name",
        "difficulty",
        "video_generation_risk",
        "visual_clarity",
        "suitable_shot_functions",
        "required_props",
        "best_camera",
        "start_state",
        "main_motion",
        "end_state",
        "avoid"
      ],
      "title": "ProductAction",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "source_artifacts": {
      "items": {
        "type": "string"
      },
      "title": "Source Artifacts",
      "type": "array"
    },
    "model_info": {
      "$ref": "#/$defs/ModelInfo"
    },
    "cost_rmb": {
      "default": 0.0,
      "minimum": 0,
      "title": "Cost Rmb",
      "type": "number"
    },
    "product_action_matrix": {
      "items": {
        "$ref": "#/$defs/ProductAction"
      },
      "title": "Product Action Matrix",
      "type": "array"
    }
  },
  "required": [
    "project_id",
    "artifact_id",
    "created_at",
    "model_info",
    "product_action_matrix"
  ],
  "title": "ProductActionMatrixArtifact",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "product_action_matrix.schema.json"
}
