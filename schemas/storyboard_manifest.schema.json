{
  "$defs": {
    "ModelInfo": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelInfo",
      "type": "object"
    },
    "Storyboard": {
      "additionalProperties": false,
      "properties": {
        "new_shot_id": {
          "title": "New Shot Id",
          "type": "string"
        },
        "image_id": {
          "title": "Image Id",
          "type": "string"
        },
        "image_path": {
          "title": "Image Path",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "source_prompt_id": {
          "title": "Source Prompt Id",
          "type": "string"
        },
        "selected": {
          "title": "Selected",
          "type": "boolean"
        }
      },
      "required": [
        "new_shot_id",
        "image_id",
        "image_path",
        "model",
        "source_prompt_id",
        "selected"
      ],
      "title": "Storyboard",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "source_artifacts": {
      "items": {
        "type": "string"
      },
      "title": "Source Artifacts",
      "type": "array"
    },
    "model_info": {
      "$ref": "#/$defs/ModelInfo"
    },
    "cost_rmb": {
      "default": 0.0,
      "minimum": 0,
      "title": "Cost Rmb",
      "type": "number"
    },
    "storyboards": {
      "items": {
        "$ref": "#/$defs/Storyboard"
      },
      "title": "Storyboards",
      "type": "array"
    }
  },
  "required": [
    "project_id",
    "artifact_id",
    "created_at",
    "model_info",
    "storyboards"
  ],
  "title": "StoryboardManifestArtifact",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "storyboard_manifest.schema.json"
}
