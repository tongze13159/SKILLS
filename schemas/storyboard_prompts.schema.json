{
  "$defs": {
    "ModelInfo": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelInfo",
      "type": "object"
    },
    "StoryboardPrompt": {
      "additionalProperties": false,
      "properties": {
        "new_shot_id": {
          "pattern": "^new_\\d{3}$",
          "title": "New Shot Id",
          "type": "string"
        },
        "image_model": {
          "title": "Image Model",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "negative_prompt": {
          "title": "Negative Prompt",
          "type": "string"
        },
        "reference_image_ids": {
          "items": {
            "type": "string"
          },
          "title": "Reference Image Ids",
          "type": "array"
        },
        "aspect_ratio": {
          "title": "Aspect Ratio",
          "type": "string"
        },
        "resolution": {
          "title": "Resolution",
          "type": "string"
        },
        "action_start_state": {
          "title": "Action Start State",
          "type": "string"
        },
        "purpose": {
          "const": "first_frame_for_seedance",
          "title": "Purpose",
          "type": "string"
        }
      },
      "required": [
        "new_shot_id",
        "image_model",
        "prompt",
        "negative_prompt",
        "reference_image_ids",
        "aspect_ratio",
        "resolution",
        "action_start_state",
        "purpose"
      ],
      "title": "StoryboardPrompt",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "source_artifacts": {
      "items": {
        "type": "string"
      },
      "title": "Source Artifacts",
      "type": "array"
    },
    "model_info": {
      "$ref": "#/$defs/ModelInfo"
    },
    "cost_rmb": {
      "default": 0.0,
      "minimum": 0,
      "title": "Cost Rmb",
      "type": "number"
    },
    "storyboard_prompts": {
      "items": {
        "$ref": "#/$defs/StoryboardPrompt"
      },
      "title": "Storyboard Prompts",
      "type": "array"
    }
  },
  "required": [
    "project_id",
    "artifact_id",
    "created_at",
    "model_info",
    "storyboard_prompts"
  ],
  "title": "StoryboardPromptsArtifact",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "storyboard_prompts.schema.json"
}
