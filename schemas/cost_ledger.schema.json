{
  "$defs": {
    "ModelInfo": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelInfo",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "source_artifacts": {
      "items": {
        "type": "string"
      },
      "title": "Source Artifacts",
      "type": "array"
    },
    "model_info": {
      "$ref": "#/$defs/ModelInfo"
    },
    "cost_rmb": {
      "default": 0.0,
      "minimum": 0,
      "title": "Cost Rmb",
      "type": "number"
    },
    "budget_rmb": {
      "minimum": 0,
      "title": "Budget Rmb",
      "type": "number"
    },
    "warn_budget_rmb": {
      "minimum": 0,
      "title": "Warn Budget Rmb",
      "type": "number"
    },
    "spent_rmb": {
      "minimum": 0,
      "title": "Spent Rmb",
      "type": "number"
    },
    "estimated_rmb": {
      "minimum": 0,
      "title": "Estimated Rmb",
      "type": "number"
    },
    "items": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Items",
      "type": "array"
    }
  },
  "required": [
    "project_id",
    "artifact_id",
    "created_at",
    "model_info",
    "budget_rmb",
    "warn_budget_rmb",
    "spent_rmb",
    "estimated_rmb",
    "items"
  ],
  "title": "CostLedgerArtifact",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cost_ledger.schema.json"
}
