{
  "$defs": {
    "Camera": {
      "additionalProperties": false,
      "properties": {
        "angle": {
          "title": "Angle",
          "type": "string"
        },
        "distance": {
          "title": "Distance",
          "type": "string"
        },
        "movement": {
          "title": "Movement",
          "type": "string"
        }
      },
      "required": [
        "angle",
        "distance",
        "movement"
      ],
      "title": "Camera",
      "type": "object"
    },
    "ModelInfo": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelInfo",
      "type": "object"
    },
    "NewShot": {
      "additionalProperties": false,
      "properties": {
        "new_shot_id": {
          "pattern": "^new_\\d{3}$",
          "title": "New Shot Id",
          "type": "string"
        },
        "reference_shot_id": {
          "pattern": "^ref_\\d{3}$",
          "title": "Reference Shot Id",
          "type": "string"
        },
        "duration_ms": {
          "exclusiveMinimum": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "start_ms": {
          "minimum": 0,
          "title": "Start Ms",
          "type": "integer"
        },
        "end_ms": {
          "exclusiveMinimum": 0,
          "title": "End Ms",
          "type": "integer"
        },
        "shot_function": {
          "enum": [
            "hook",
            "pain_point",
            "product_reveal",
            "function_demo",
            "proof",
            "comparison",
            "scenario",
            "transition",
            "cta"
          ],
          "title": "Shot Function",
          "type": "string"
        },
        "commercial_purpose": {
          "title": "Commercial Purpose",
          "type": "string"
        },
        "selected_action_id": {
          "title": "Selected Action Id",
          "type": "string"
        },
        "visual_action": {
          "title": "Visual Action",
          "type": "string"
        },
        "camera": {
          "$ref": "#/$defs/Camera"
        },
        "scene": {
          "$ref": "#/$defs/Scene"
        },
        "product_focus": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Product Focus",
          "type": "array"
        },
        "subtitle_intent": {
          "title": "Subtitle Intent",
          "type": "string"
        },
        "voiceover_intent": {
          "title": "Voiceover Intent",
          "type": "string"
        },
        "must_keep_from_reference": {
          "items": {
            "type": "string"
          },
          "title": "Must Keep From Reference",
          "type": "array"
        },
        "must_change_from_reference": {
          "items": {
            "type": "string"
          },
          "title": "Must Change From Reference",
          "type": "array"
        },
        "generation_risks": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Generation Risks",
          "type": "array"
        },
        "source_new_shot_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Source New Shot Ids",
          "type": "array"
        },
        "source_reference_shot_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Source Reference Shot Ids",
          "type": "array"
        },
        "generation_strategy": {
          "enum": [
            "standalone",
            "adjacent_merge",
            "shot_split"
          ],
          "title": "Generation Strategy",
          "type": "string"
        }
      },
      "required": [
        "new_shot_id",
        "reference_shot_id",
        "duration_ms",
        "start_ms",
        "end_ms",
        "shot_function",
        "commercial_purpose",
        "selected_action_id",
        "visual_action",
        "camera",
        "scene",
        "product_focus",
        "subtitle_intent",
        "voiceover_intent",
        "must_keep_from_reference",
        "must_change_from_reference",
        "generation_risks",
        "source_new_shot_ids",
        "source_reference_shot_ids",
        "generation_strategy"
      ],
      "title": "NewShot",
      "type": "object"
    },
    "NewVideoPlanBody": {
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "title": "Project Id",
          "type": "string"
        },
        "duration_ms": {
          "exclusiveMinimum": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "shot_count": {
          "exclusiveMinimum": 0,
          "title": "Shot Count",
          "type": "integer"
        },
        "target_language": {
          "title": "Target Language",
          "type": "string"
        },
        "voice_gender": {
          "title": "Voice Gender",
          "type": "string"
        },
        "shots": {
          "items": {
            "$ref": "#/$defs/NewShot"
          },
          "title": "Shots",
          "type": "array"
        },
        "source_reference_shot_count": {
          "exclusiveMinimum": 0,
          "title": "Source Reference Shot Count",
          "type": "integer"
        }
      },
      "required": [
        "project_id",
        "duration_ms",
        "shot_count",
        "target_language",
        "voice_gender",
        "shots"
      ],
      "title": "NewVideoPlanBody",
      "type": "object"
    },
    "Scene": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "background": {
          "title": "Background",
          "type": "string"
        }
      },
      "required": [
        "type",
        "background"
      ],
      "title": "Scene",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "source_artifacts": {
      "items": {
        "type": "string"
      },
      "title": "Source Artifacts",
      "type": "array"
    },
    "model_info": {
      "$ref": "#/$defs/ModelInfo"
    },
    "cost_rmb": {
      "default": 0.0,
      "minimum": 0,
      "title": "Cost Rmb",
      "type": "number"
    },
    "new_video_plan": {
      "$ref": "#/$defs/NewVideoPlanBody"
    }
  },
  "required": [
    "project_id",
    "artifact_id",
    "created_at",
    "model_info",
    "new_video_plan"
  ],
  "title": "NewVideoPlanArtifact",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "new_video_plan.schema.json"
}
