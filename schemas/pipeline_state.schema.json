{
  "$defs": {
    "ModelInfo": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelInfo",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "source_artifacts": {
      "items": {
        "type": "string"
      },
      "title": "Source Artifacts",
      "type": "array"
    },
    "model_info": {
      "$ref": "#/$defs/ModelInfo"
    },
    "cost_rmb": {
      "default": 0.0,
      "minimum": 0,
      "title": "Cost Rmb",
      "type": "number"
    },
    "status": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "blocked"
      ],
      "title": "Status",
      "type": "string"
    },
    "dry_run": {
      "title": "Dry Run",
      "type": "boolean"
    },
    "current_step": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Current Step"
    },
    "steps": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Steps",
      "type": "object"
    },
    "total_cost_rmb": {
      "minimum": 0,
      "title": "Total Cost Rmb",
      "type": "number"
    },
    "max_budget_rmb": {
      "minimum": 0,
      "title": "Max Budget Rmb",
      "type": "number"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    }
  },
  "required": [
    "project_id",
    "artifact_id",
    "created_at",
    "model_info",
    "status",
    "dry_run",
    "steps",
    "total_cost_rmb",
    "max_budget_rmb"
  ],
  "title": "PipelineStateArtifact",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pipeline_state.schema.json"
}
